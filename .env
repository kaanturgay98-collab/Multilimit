# Database Configuration
# Prisma supports PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# Default for this project is SQLite.
DATABASE_URL="file:./app.db"
TYPEORM_SYNCHRONIZE=true
TYPEORM_LOGGING=false

# Admin Authentication Settings
# Default username for the admin panel
ADMIN_USERNAME="admin"

# Admin Password Hash
# Format: "<saltBase64>:<hashBase64>"
# Use a secure script to generate this for production.
# Default dev password is often "admin" or similar (check your local .env)
ADMIN_PASSWORD_HASH="bUb3xi+N6ExgN/aXI+JsVQ==:tNbyOeCc+bZRDSQsRysWVXHAsKXD57//674q1V7h6eY="

# JWT Security
# Change this to a long, random string in production!
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_FOR_PRODUCTION"

# Admin Session TTL (Time To Live) in seconds (86400 = 24 hours)
ADMIN_JWT_TTL_SECONDS="86400"

# Prisma Engine Configuration
# Use "binary" to force the classic engine and avoid adapter requirements.
PRISMA_CLIENT_ENGINE_TYPE="binary"

# Public App URL (Used for Puck editor and metadata)
# For local development: http://localhost:3000
# For production: https://mltlimit.com
NEXT_PUBLIC_APP_URL="https://mltlimit.com"


# Optional: External API Keys (if applicable)
# STRIPE_SECRET_KEY=""
# RESEND_API_KEY=""
